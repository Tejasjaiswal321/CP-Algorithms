struct TreeLinkNode {
    int val;
    TreeLinkNode *left,*right,*next;
    TreeLinkNode(int x) : val(x), left(NULL), right(NULL), next(NULL) {}
};


class Solution{
    public:
        void connect(TreeLinkNode* A);
};

void Solution::connect(TreeLinkNode* A) {
    auto node = A;
    while(node!=NULL){
        TreeLinkNode * startNode,*leftNode = node,*prevNodeRChild= NULL;
        while(leftNode!=NULL){
            printf("%d -> %d\n",leftNode->left->val,leftNode->right->val);
            leftNode->left->next = leftNode->right;
            if(prevNodeRChild!=NULL){
                prevNodeRChild->next = leftNode->left;
                printf("rchild: %d -> %d\n",prevNodeRChild->next->val,leftNode->left->val);
            }
            prevNodeRChild = leftNode->right;
            leftNode = leftNode->next;
        }

        node = startNode->left;
    }
}

